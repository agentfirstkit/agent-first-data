{
  "name": "agent-first-data",
  "version": "0.14.2",
  "description": "A naming convention that lets AI agents understand your data without being told what it means.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentfirstkit/agent-first-data"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./afdata_logging": {
      "import": "./dist/afdata_logging.js",
      "types": "./dist/afdata_logging.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "tsx --test src/*.test.ts examples/agent_cli.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
